rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Users can only read and write their own activity log
      match /activities/{activityId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Users can only read and write their own analyses
      match /analyses/{analysisId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Users can read and write their own monthly usage counters
      match /usage/{monthKey} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Anyone can submit a contact message (no auth required)
    match /contacts/{contactId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string;
      allow read, update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
